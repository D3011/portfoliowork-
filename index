  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f5f4f0; --white: #fff; --navy: #0f1f3d;
      --blue: #1d4ed8; --blue-light: #3b6ef5;
      --accent: #e8f0fe; --muted: #6b7280;
      --border: #e2e5ec; --text: #1a202c;
      --shadow-lg: 0 12px 48px rgba(15,31,61,0.14);
    }
    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--text); font-family: 'Outfit', sans-serif; overflow-x: hidden; }

    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 500;
      background: rgba(255,255,255,0.93); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 0 64px; height: 68px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo { font-weight: 800; font-size: 1.1rem; color: var(--navy); text-decoration: none; }
    .nav-logo span { color: var(--blue); }
    .nav-back { display: inline-flex; align-items: center; gap: 8px; font-size: 0.85rem; font-weight: 600; color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .nav-back:hover { color: var(--navy); }
    .nav-hire { background: var(--navy); color: #fff; padding: 10px 22px; border-radius: 8px; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: background 0.2s; }
    .nav-hire:hover { background: var(--blue); }

    /* HERO */
    .work-hero {
      padding: 120px 64px 64px;
      background: var(--white);
      border-bottom: 1px solid var(--border);
      text-align: center;
    }
    .eyebrow { display: inline-flex; align-items: center; gap: 8px; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--blue); margin-bottom: 16px; }
    .eyebrow::before { content: ''; width: 20px; height: 2px; background: var(--blue); border-radius: 2px; }
    .eyebrow::after { content: ''; width: 20px; height: 2px; background: var(--blue); border-radius: 2px; }
    .work-title { font-family: 'Fraunces', serif; font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 400; color: var(--navy); margin-bottom: 16px; line-height: 1.1; }
    .work-title em { font-style: italic; color: var(--blue); }
    .work-sub { font-size: 1rem; color: var(--muted); max-width: 520px; margin: 0 auto; line-height: 1.7; }

    /* PROJECT SECTIONS */
    .project-section { padding: 80px 64px; }
    .project-section:nth-child(even) { background: var(--white); }
    .project-section:nth-child(odd) { background: var(--bg); }

    .proj-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 40px; margin-bottom: 40px; flex-wrap: wrap; }
    .proj-meta { flex: 1; min-width: 260px; }
    .proj-badge { display: inline-block; padding: 5px 14px; border-radius: 100px; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }
    .badge-college { background: var(--accent); color: var(--blue); }
    .badge-restaurant { background: #fff7ed; color: #c2410c; }
    .proj-name { font-family: 'Fraunces', serif; font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 400; color: var(--navy); line-height: 1.2; margin-bottom: 12px; }
    .proj-name em { font-style: italic; color: var(--blue); }
    .proj-desc { font-size: 0.95rem; color: var(--muted); line-height: 1.7; max-width: 480px; }
    .proj-details { display: flex; gap: 28px; margin-top: 20px; flex-wrap: wrap; }
    .proj-detail { }
    .pd-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 4px; }
    .pd-value { font-size: 0.875rem; font-weight: 600; color: var(--navy); }

    .proj-action { display: flex; align-items: flex-start; gap: 12px; flex-shrink: 0; flex-wrap: wrap; }
    .btn-visit {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 14px 28px; border-radius: 10px;
      font-family: 'Outfit', sans-serif; font-size: 0.875rem; font-weight: 600;
      text-decoration: none; transition: all 0.25s ease;
    }
    .btn-visit-primary { background: var(--navy); color: #fff; }
    .btn-visit-primary:hover { background: var(--blue); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(29,78,216,0.3); }
    .btn-visit-outline { background: transparent; border: 1.5px solid var(--border); color: var(--navy); }
    .btn-visit-outline:hover { border-color: var(--navy); background: var(--navy); color: #fff; transform: translateY(-2px); }

    /* BROWSER MOCKUP */
    .browser-mockup {
      border-radius: 12px;
      overflow: hidden;
      box-shadow: var(--shadow-lg), 0 0 0 1px var(--border);
      background: var(--white);
      position: relative;
    }
    .browser-bar {
      background: #f1f3f4;
      border-bottom: 1px solid var(--border);
      padding: 10px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .browser-dots { display: flex; gap: 6px; }
    .browser-dot { width: 12px; height: 12px; border-radius: 50%; }
    .bd-red { background: #ff5f57; }
    .bd-yellow { background: #febc2e; }
    .bd-green { background: #28c840; }
    .browser-url {
      flex: 1;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 5px 12px;
      font-size: 0.72rem;
      color: var(--muted);
      font-family: monospace;
      display: flex;
      align-items: center;
      gap: 6px;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }
    .url-lock { color: #22c55e; font-size: 0.7rem; }
    .browser-frame {
      position: relative;
      height: 540px;
      overflow: hidden;
    }
    .browser-frame iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }
    /* Fallback shown if iframe blocked */
    .iframe-fallback {
      display: none;
      position: absolute;
      inset: 0;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 16px;
      background: linear-gradient(135deg, #0f1f3d 0%, #1a3260 100%);
      color: white;
      text-align: center;
      padding: 40px;
    }
    .iframe-fallback.restaurant-fb { background: linear-gradient(135deg, #1a0500 0%, #3b0f00 100%); }
    .ifb-icon { font-size: 3rem; margin-bottom: 8px; }
    .ifb-title { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 300; }
    .ifb-sub { font-size: 0.8rem; opacity: 0.6; margin-top: 4px; }
    .ifb-btn { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: white; padding: 10px 20px; border-radius: 8px; font-size: 0.8rem; font-weight: 600; text-decoration: none; margin-top: 8px; transition: background 0.2s; }
    .ifb-btn:hover { background: rgba(255,255,255,0.22); }

    /* overlay click-through for the iframe */
    .browser-overlay {
      position: absolute;
      inset: 0;
      cursor: pointer;
      z-index: 10;
      background: transparent;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      padding-bottom: 24px;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .browser-mockup:hover .browser-overlay { opacity: 1; }
    .overlay-hint {
      background: rgba(15,31,61,0.85);
      color: white;
      padding: 10px 24px;
      border-radius: 100px;
      font-size: 0.8rem;
      font-weight: 600;
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.15);
      pointer-events: none;
    }

    /* TAGS ROW */
    .tags-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
    .work-tag { padding: 5px 12px; border-radius: 6px; font-size: 0.72rem; font-weight: 600; }
    .wt-blue { background: var(--accent); color: var(--blue); }
    .wt-green { background: #f0fdf4; color: #16a34a; }
    .wt-purple { background: #faf5ff; color: #7c3aed; }
    .wt-orange { background: #fff7ed; color: #c2410c; }

    /* CTA */
    .work-cta {
      background: var(--navy);
      padding: 80px 64px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .work-cta::before { content:''; position:absolute; top:-200px; right:-200px; width:500px; height:500px; border-radius:50%; background:radial-gradient(circle,rgba(29,78,216,0.3) 0%,transparent 70%); }
    .cta-inner { position: relative; z-index: 2; }
    .cta-title { font-family: 'Fraunces', serif; font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 400; color: white; margin-bottom: 14px; }
    .cta-title em { font-style: italic; color: #60a5fa; }
    .cta-sub { color: rgba(255,255,255,0.55); font-size: 0.95rem; margin-bottom: 36px; }
    .cta-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
    .btn-cta-primary { background: var(--blue-light); color: white; padding: 14px 32px; border-radius: 10px; font-family: 'Outfit',sans-serif; font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: all 0.25s; }
    .btn-cta-primary:hover { background: #5b8af7; transform: translateY(-2px); }
    .btn-cta-wa { display: inline-flex; align-items: center; gap: 8px; background: #25d366; color: white; padding: 14px 32px; border-radius: 10px; font-family: 'Outfit',sans-serif; font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: all 0.25s; }
    .btn-cta-wa:hover { background: #1ebe5d; transform: translateY(-2px); }

    footer { background: #080f1e; padding: 28px 64px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; border-top: 1px solid rgba(255,255,255,0.05); }
    .footer-logo { font-weight: 800; font-size: 1rem; color: #fff; }
    .footer-logo span { color: var(--blue-light); }
    .footer-copy { font-size: 0.75rem; color: rgba(255,255,255,0.3); }

    .wa-float { position: fixed; bottom: 32px; right: 32px; z-index: 600; width: 56px; height: 56px; border-radius: 50%; background: #25d366; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 28px rgba(37,211,102,0.4); text-decoration: none; transition: transform 0.25s; animation: wa-pulse 2.8s ease-in-out infinite; }
    .wa-float:hover { transform: scale(1.1); }
    .wa-float svg { width: 26px; height: 26px; fill: white; }
    @keyframes wa-pulse { 0%,100%{box-shadow:0 8px 28px rgba(37,211,102,0.4)} 50%{box-shadow:0 8px 40px rgba(37,211,102,0.6),0 0 0 8px rgba(37,211,102,0.08)} }

    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 900px) {
      nav { padding: 0 20px; }
      .work-hero, .project-section, .work-cta { padding-left: 20px; padding-right: 20px; }
      .proj-header { flex-direction: column; }
      .browser-frame { height: 320px; }
      footer { padding: 24px 20px; }
    }
  </style>
</head>
