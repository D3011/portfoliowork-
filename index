  <script>
    // Scroll reveal
    const reveals = document.querySelectorAll('.reveal');
    const obs = new IntersectionObserver(entries => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) { setTimeout(() => e.target.classList.add('visible'), i * 100); obs.unobserve(e.target); }
      });
    }, { threshold: 0.08 });
    reveals.forEach(el => obs.observe(el));

    // Scroll to anchor on load
    window.addEventListener('load', () => {
      const hash = window.location.hash;
      if (hash) {
        setTimeout(() => {
          const el = document.querySelector(hash);
          if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 300);
      }
    });

    // Iframe fallback detection
    function checkIframe(iframe, fallbackId) {
      try {
        // If the iframe loaded but is blocked (blank), show fallback after short delay
        setTimeout(() => {
          try {
            const doc = iframe.contentDocument || iframe.contentWindow.document;
            if (!doc || doc.body.innerHTML === '') showFallback(fallbackId);
          } catch(e) {
            // Cross-origin: frame loaded OK, don't show fallback
          }
        }, 3000);
      } catch(e) {
        showFallback(fallbackId);
      }
    }

    function showFallback(id) {
      const fb = document.getElementById(id);
      if (fb) {
        fb.style.display = 'flex';
        // Hide the corresponding iframe
        const iframe = fb.previousElementSibling;
        if (iframe && iframe.tagName === 'IFRAME') iframe.style.display = 'none';
      }
    }
  </script>
